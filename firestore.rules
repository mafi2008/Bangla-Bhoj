rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "fatamajohora493@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'image', 'description', 'stock', 'category', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.image is string && data.image.size() < 500 &&
             data.description is string && data.description.size() < 2000 &&
             data.stock is number && data.stock >= 0 &&
             data.category is string && data.category.size() < 50 &&
             data.createdAt is timestamp &&
             (!('flavour' in data) || (data.flavour is list && data.flavour.size() <= 10));
    }

    function isValidOrder(data) {
      return hasRequiredFields(['customerName', 'phone', 'division', 'district', 'address', 'items', 'totalPrice', 'paymentMethod', 'status', 'createdAt']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() < 20 &&
             data.division is string && data.division.size() > 0 && data.division.size() < 50 &&
             data.district is string && data.district.size() > 0 && data.district.size() < 50 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.paymentMethod in ['COD', 'bKash', 'Nagad', 'Rocket'] &&
             data.status in ['pending', 'confirmed', 'delivered', 'cancelled'] &&
             data.createdAt is timestamp &&
             (!('alternativePhone' in data) || (data.alternativePhone is string && data.alternativePhone.size() < 20)) &&
             (!('orderNotes' in data) || (data.orderNotes is string && data.orderNotes.size() < 1000)) &&
             (!('deliveryCharge' in data) || (data.deliveryCharge is number && data.deliveryCharge >= 0));
    }

    function isValidUser(data) {
      return hasRequiredFields(['email', 'role', 'createdAt']) &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['admin', 'customer'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      // Anyone can read products
      allow read: if true;
      // Only admins can create/update/delete products
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Admins can read all orders. Users cannot read orders (they just get a confirmation screen after placement).
      allow read: if isAdmin();
      // Anyone can create an order (guest checkout is allowed)
      allow create: if isValidOrder(request.resource.data) && request.resource.data.status == 'pending';
      // Only admins can update orders (e.g., change status)
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Admins can read all users. Users can read their own profile.
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      // Only admins can create/update users (or the system via Cloud Functions, but we restrict client writes here)
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
